            <property name="styleSheet">
             <string notr="true">QTabBar {
            background: #00ffffff;
            color: #ff000000;

            font-size: 10pt;
        }
        QTabBar::tab {
            background: {black};
            color: #000000;
            border-width: 2px;
            border-style: solid;
            border-color: #0000ff;
            border-bottom-color: #00ffffff;
            border-top-left-radius: 6px;
            border-top-right-radius: 6px;
            min-height: 80px;
            padding: 3px;
        }
        QTabBar::tab:selected {
            border-color: rgb(170, 170, 170);
            border-bottom-color: rgb(0, 170, 127);
        }
        QTabBar::tab:!selected {
            margin-top: 2px;
        }</string>
